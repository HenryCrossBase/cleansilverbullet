# Runtime mode: use "production" in deployed environments.
NODE_ENV=development

# Enable API documentation endpoints (/docs and /docs.json).
DOCS=false

# API port for backend server.
PORT=3001

# Primary Prisma connection URL (application queries).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/silverbullet?schema=public

# Prisma direct URL for migrations (if omitted in local env, use DATABASE_URL value).
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/silverbullet?schema=public

# JWT signing key (required, secret).
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# JWT lifetime.
JWT_EXPIRES_IN=8h

# Admin Telegram bot token (secret).
ADMIN_BOT_TOKEN=REPLACE_WITH_ADMIN_BOT_TOKEN

# Shared admin Telegram group/chat ID.
ADMIN_CHAT_ID=-4998046800

# Comma-separated Telegram user IDs allowed to operate admin bot.
ADMIN_USER_IDS=REPLACE_WITH_COMMA_SEPARATED_TELEGRAM_USER_IDS

# Vendor Telegram bot token (secret).
VENDOR_BOT_TOKEN=REPLACE_WITH_VENDOR_BOT_TOKEN

# Cloudflare Turnstile secret for non-production/dev.
CF_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET_FOR_NON_PROD

# Cloudflare Turnstile secret for production.
CF_SECRET_KEY_PRODUCTION=REPLACE_WITH_TURNSTILE_SECRET_FOR_PROD

# Public app base URL used for outbound links.
APP_BASE_URL=https://silverbullet.to

# Explicit vendor dashboard URL used in notifications.
VENDOR_DASHBOARD_URL=https://silverbullet.to/vendor/dashboard

# Comma-separated frontend origins allowed by backend CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OxaPay hosted checkout endpoint.
OXAPAY_CHECKOUT_URL=https://oxapay.com/checkout

# OxaPay paylink base endpoint.
OXAPAY_PAYLINK_BASE=https://oxapay.com/checkout

# Legacy owner behavior compatibility flag.
ALLOW_LEGACY_OWNER=false

# Optional Redis URL for auth state caching.
REDIS_URL=redis://127.0.0.1:6379

# In-memory/redis auth cache TTL in milliseconds.
AUTH_CACHE_TTL_MS=60000

# Redis key prefix for auth cache entries.
AUTH_CACHE_KEY_PREFIX=sb:auth:user:

# Optional load test target URL.
LOAD_TEST_BASE_URL=http://127.0.0.1:3001

# Optional load test duration in seconds.
LOAD_TEST_DURATION=8

# Optional load test concurrent connections.
LOAD_TEST_CONNECTIONS=20

# Optional load test pipelining factor.
LOAD_TEST_PIPELINING=1
